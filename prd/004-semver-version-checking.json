{
  "id": "PRD-004",
  "title": "Semantic Version Checking",
  "version": "1.0.0",
  "status": "proposed",
  "priority": "high",
  "tier": 1,
  "created": "2025-01-13",
  "overview": "Replace the current substring-based version matching with proper semantic versioning support, enabling version ranges and accurate version comparison.",
  "problem_statement": {
    "summary": "Current version checking in cmd_satisfies() uses simple substring matching which causes false positives and negatives.",
    "current_implementation": {
      "file": "src/tools/common.rs",
      "lines": "154-160",
      "code": "pub fn cmd_satisfies(cmd: &str, min_prefix: &str) -> bool {\n    if let Ok(out) = Command::new(cmd).arg(\"--version\").output() {\n        let s = String::from_utf8_lossy(&out.stdout);\n        return s.contains(min_prefix);  // BUG: Substring match!\n    }\n    false\n}"
    },
    "issues": [
      {
        "type": "false_positive",
        "description": "\"2.4\" matches \"12.40\", \"2.401\", \"v2.4.0-beta\""
      },
      {
        "type": "false_negative",
        "description": "\"2.40\" doesn't match \"2.40.1\" if user expects it to"
      },
      {
        "type": "missing_feature",
        "description": "No range support - can't specify \">= 3.10, < 4.0\""
      }
    ],
    "evidence": [
      "cmd_satisfies(\"git\", \"2.4\") returns TRUE if git version is \"1.24\" (contains \"2.4\")",
      "User specifies python = \"3.10\" expecting 3.10+, but 3.9 with substring \"3.1\" might pass",
      "No tests exist for version matching logic"
    ]
  },
  "requirements": {
    "functional": [
      {
        "id": "FR-001",
        "name": "Exact version matching",
        "description": "\"3.10.0\" matches only 3.10.0"
      },
      {
        "id": "FR-002",
        "name": "Prefix matching",
        "description": "\"3.10\" matches 3.10.x"
      },
      {
        "id": "FR-003",
        "name": "Range expressions",
        "description": "Support \">= 3.10\", \"< 4.0\", \">= 3.10, < 4.0\""
      },
      {
        "id": "FR-004",
        "name": "Wildcards",
        "description": "Support \"3.x\", \"3.10.x\", \"*\" (any version)"
      },
      {
        "id": "FR-005",
        "name": "Latest keyword",
        "description": "\"latest\" always passes (skip check)"
      },
      {
        "id": "FR-006",
        "name": "Prerelease handling",
        "description": "\"3.10.0-beta\" recognized but not matched by \"3.10\""
      }
    ],
    "non_functional": [
      {
        "id": "NFR-001",
        "name": "Universal parsing",
        "description": "Parse version output from any tool format"
      },
      {
        "id": "NFR-002",
        "name": "Component handling",
        "description": "Handle missing version components (e.g., \"3\" → \"3.0.0\")"
      },
      {
        "id": "NFR-003",
        "name": "Graceful fallback",
        "description": "Support non-semver versions gracefully (fall back to prefix match)"
      },
      {
        "id": "NFR-004",
        "name": "Performance",
        "description": "Zero performance regression on version checks"
      }
    ]
  },
  "version_formats": [
    {
      "tool": "git",
      "output": "git version 2.44.0",
      "extracted": "2.44.0"
    },
    {
      "tool": "node",
      "output": "v20.10.0",
      "extracted": "20.10.0"
    },
    {
      "tool": "python",
      "output": "Python 3.12.1",
      "extracted": "3.12.1"
    },
    {
      "tool": "docker",
      "output": "Docker version 24.0.7, build afdd53b",
      "extracted": "24.0.7"
    },
    {
      "tool": "rustc",
      "output": "rustc 1.75.0 (82e1608df 2023-12-21)",
      "extracted": "1.75.0"
    },
    {
      "tool": "go",
      "output": "go version go1.21.5 darwin/arm64",
      "extracted": "1.21.5"
    }
  ],
  "technical_approach": {
    "version_extraction": {
      "regex_pattern": "v?(\\d+)\\.(\\d+)(?:\\.(\\d+))?(?:-([a-zA-Z0-9.-]+))?",
      "implementation": {
        "language": "rust",
        "code": "use regex::Regex;\n\nlazy_static! {\n    static ref VERSION_REGEX: Regex = Regex::new(\n        r\"v?(\\d+)\\.(\\d+)(?:\\.(\\d+))?(?:-([a-zA-Z0-9.-]+))?\"\n    ).unwrap();\n}\n\npub fn extract_version(output: &str) -> Option<Version> {\n    VERSION_REGEX.captures(output).map(|caps| {\n        Version {\n            major: caps[1].parse().unwrap(),\n            minor: caps[2].parse().unwrap(),\n            patch: caps.get(3).map(|m| m.as_str().parse().unwrap()).unwrap_or(0),\n            prerelease: caps.get(4).map(|m| m.as_str().to_string()),\n        }\n    })\n}"
      }
    },
    "version_comparison": {
      "implementation": {
        "language": "rust",
        "code": "use semver::{Version, VersionReq};\n\npub fn version_satisfies(installed: &str, requirement: &str) -> bool {\n    // Handle special cases\n    if requirement == \"latest\" || requirement == \"*\" {\n        return true;\n    }\n\n    // Try to parse as semver requirement\n    if let Ok(req) = VersionReq::parse(requirement) {\n        if let Some(ver) = extract_version(installed) {\n            return req.matches(&ver);\n        }\n    }\n\n    // Fall back to prefix matching for non-semver\n    installed.contains(requirement)\n}"
      }
    },
    "syntax_reference": [
      {
        "syntax": "3.10",
        "meaning": "3.10.x (any patch)",
        "example_matches": ["3.10.0", "3.10.5"]
      },
      {
        "syntax": "3.10.0",
        "meaning": "Exactly 3.10.0",
        "example_matches": ["3.10.0"]
      },
      {
        "syntax": ">= 3.10",
        "meaning": "3.10 or higher",
        "example_matches": ["3.10", "3.11", "4.0"]
      },
      {
        "syntax": "< 4.0",
        "meaning": "Less than 4.0",
        "example_matches": ["3.x"]
      },
      {
        "syntax": ">= 3.10, < 4.0",
        "meaning": "Range",
        "example_matches": ["3.10", "3.11", "3.99"]
      },
      {
        "syntax": "~3.10",
        "meaning": "Compatible with 3.10",
        "example_matches": ["3.10.x"]
      },
      {
        "syntax": "^3.10",
        "meaning": "Compatible with 3.x",
        "example_matches": ["3.10+"]
      },
      {
        "syntax": "latest",
        "meaning": "Skip version check",
        "example_matches": ["*"]
      },
      {
        "syntax": "*",
        "meaning": "Any version",
        "example_matches": ["*"]
      }
    ]
  },
