  "test_cases": [
    {
      "name": "test_version_extraction",
      "type": "unit",
      "assertions": [
        {
          "input": "git version 2.44.0",
          "expected": {"major": 2, "minor": 44, "patch": 0}
        },
        {
          "input": "v20.10.0",
          "expected": {"major": 20, "minor": 10, "patch": 0}
        },
        {
          "input": "Python 3.12.1",
          "expected": {"major": 3, "minor": 12, "patch": 1}
        },
        {
          "input": "go1.21.5",
          "expected": {"major": 1, "minor": 21, "patch": 5}
        }
      ]
    },
    {
      "name": "test_version_satisfies_prefix",
      "type": "unit",
      "assertions": [
        {
          "installed": "2.44.0",
          "requirement": "2.44",
          "expected": true
        },
        {
          "installed": "2.43.0",
          "requirement": "2.44",
          "expected": false
        }
      ]
    },
    {
      "name": "test_version_satisfies_range",
      "type": "unit",
      "assertions": [
        {
          "installed": "3.10.5",
          "requirement": ">= 3.10, < 4.0",
          "expected": true
        },
        {
          "installed": "4.0.0",
          "requirement": ">= 3.10, < 4.0",
          "expected": false
        }
      ]
    },
    {
      "name": "test_version_satisfies_wildcards",
      "type": "unit",
      "assertions": [
        {
          "installed": "1.0.0",
          "requirement": "*",
          "expected": true
        },
        {
          "installed": "99.0.0",
          "requirement": "latest",
          "expected": true
        }
      ]
    },
    {
      "name": "test_version_satisfies_bug_fix",
      "type": "unit",
      "description": "Verify the substring bug is fixed",
      "assertions": [
        {
          "installed": "12.40.0",
          "requirement": "2.4",
          "expected": false,
          "comment": "This was the bug - substring '2.4' in '12.40' caused false positive"
        }
      ]
    }
