  "nonGoals": [
    "Docker image distribution (Jarvy provisions environments, not containers)",
    "Snap or Flatpak initially (P2/P3 priority)",
    "ARM Windows binaries (low demand)",
    "32-bit platform support"
  ],
  "technicalConsiderations": [
    {
      "area": "Cross-compilation",
      "details": "Use cross or cargo-zigbuild for Linux ARM targets from x86 runners"
    },
    {
      "area": "Code signing",
      "details": "macOS binaries may need notarization for Gatekeeper; Windows may need Authenticode"
    },
    {
      "area": "Package repository hosting",
      "details": "APT/RPM repos can use GitHub Pages or Cloudflare R2 for free hosting"
    },
    {
      "area": "Secrets management",
      "details": "GPG keys, crates.io token, Chocolatey API key stored as GitHub secrets"
    }
  ],
